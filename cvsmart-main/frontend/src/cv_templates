<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">

<link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600|Raleway:100|Montserrat|Roboto:300,400,500,700,900" rel="stylesheet">

<style>

/* GLOBAL */

body{
margin:0;
font-family:Open Sans;
background:#f4f4f4;
}

.template{
display:none;
}

.template.active{
display:block;
}

/* TEMPLATE SELECTOR */

.selector{
padding:20px;
text-align:center;
background:#222;
}

.selector button{
padding:10px 20px;
margin:5px;
border:none;
background:#66cc99;
color:white;
cursor:pointer;
}

/* ========================= */
/* TEMPLATE 1 */
/* ========================= */

.template1 .resume-wrapper{
display:flex;
min-height:100vh;
}

.template1 .profile{
width:40%;
background:white;
padding:40px;
}

.template1 .experience{
width:60%;
background:#3d3e42;
color:#9099a0;
padding:40px;
}

.template1 h1{
text-transform:uppercase;
}

/* ========================= */
/* TEMPLATE 2 */
/* ========================= */

.template2 .page{
display:flex;
max-width:1200px;
margin:40px auto;
background:white;
box-shadow:0 10px 20px rgba(0,0,0,0.2);
}

.template2 .side-bar{
width:320px;
background:#F7E0C1;
padding:30px;
}

.template2 .content-container{
flex:1;
padding:40px;
}

/* ========================= */
/* TEMPLATE 3 */
/* ========================= */

.template3 .resume-wrapper-inner{
max-width:1000px;
margin:auto;
background:white;
}

.template3 .resume-header{
background:#434E5E;
color:white;
padding:30px;
}

.template3 .row{
display:flex;
}

.template3 .col9{
width:75%;
padding:20px;
}

.template3 .col3{
width:25%;
padding:20px;
}

.progress{
height:6px;
background:#ddd;
}

.progress-bar{
height:6px;
background:#58677c;
}

</style>

</head>

<body>

<div class="selector">

<button onclick="switchTemplate(1)">Template 1</button>
<button onclick="switchTemplate(2)">Template 2</button>
<button onclick="switchTemplate(3)">Template 3</button>

</div>


<!-- TEMPLATE 1 -->

<div class="template template1 active">

<div class="resume-wrapper">

<div class="profile">

<h1>Amir Naser</h1>

<p>Email: amir@email.com</p>
<p>Phone: +251 964 798951</p>

</div>

<div class="experience">

<h2>Experience</h2>

<p>Founder – NovaTech</p>

<h2>Skills</h2>

<ul>
<li>React</li>
<li>n8n</li>
<li>Python</li>
</ul>

</div>

</div>

</div>


<!-- TEMPLATE 2 -->

<div class="template template2">

<div class="page">

<div class="side-bar">

<h2>Amir Naser</h2>

<p>Addis Ababa</p>

<h3>Skills</h3>

<p>HTML</p>
<p>CSS</p>
<p>JavaScript</p>

</div>

<div class="content-container">

<h2>Software Engineer</h2>

<h3>Experience</h3>

<p>NovaTech Founder</p>

</div>

</div>

</div>


<!-- TEMPLATE 3 -->

<div class="template template3">

<div class="resume-wrapper-inner">

<div class="resume-header">

<h1>Amir Naser</h1>

<p>Software Engineer</p>

</div>

<div class="row">

<div class="col9">

<h2>Experience</h2>

<p>Founder – NovaTech</p>

</div>

<div class="col3">

<h2>Skills</h2>

<p>n8n</p>

<div class="progress">
<div class="progress-bar" style="width:90%"></div>
</div>

</div>

</div>

</div>

</div>


<script>

function switchTemplate(num){

document.querySelectorAll(".template")
.forEach(t=>t.classList.remove("active"))

document.querySelector(".template"+num)
.classList.add("active")

}

</script>

</body>
</html>