GOOGLE_API_KEY=your-google-gemini-api-key-here

# Optional shared API key to protect the Flask API.
# For production, prefer proper user auth (e.g. Supabase JWT) instead of a public API key.
AUTHORIZED_API_KEY=

# Adzuna job search credentials
ADZUNA_APP_ID=your-adzuna-app-id-here
ADZUNA_APP_KEY=your-adzuna-app-key-here

# Optional: for JSearch API (RapidAPI) - aggregates Indeed, LinkedIn, etc.
RAPIDAPI_KEY=

